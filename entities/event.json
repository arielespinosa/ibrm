{
  "name": "Event",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Nombre del evento"
    },
    "description": {
      "type": "string",
      "description": "Descripci\u00f3n del evento"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Fecha del evento"
    },
    "time": {
      "type": "string",
      "description": "Hora del evento"
    },
    "location": {
      "type": "string",
      "description": "Lugar del evento"
    },
    "recurring": {
      "type": "boolean",
      "default": false,
      "description": "Si es un evento recurrente"
    },
    "day_of_week": {
      "type": "string",
      "enum": [
        "domingo",
        "lunes",
        "martes",
        "mi\u00e9rcoles",
        "jueves",
        "viernes",
        "s\u00e1bado"
      ],
      "description": "D\u00eda de la semana para eventos recurrentes"
    }
  },
  "required": [
    "title"
  ]
}